{
    "name": "arbour",
    "version": "1.5.0",
    "type": "module",
    "engines": {
        "node": ">= 22.14.0"
    },
    "scripts": {
        "fmt": "eslint \"**/*.{ts,vue}\" --fix",
        "lint": "eslint \"**/*.{ts,vue}\"",
        "check-ts": "tsc --noEmit",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "start": "bun ./backend/index.ts",
        "dev": "trap 'kill 0' INT TERM; bun run dev:frontend & bun run dev:backend; wait",
        "dev:backend": "NODE_ENV=development bun --watch --inspect ./backend/index.ts",
        "dev:frontend": "NODE_ENV=development vite --host --config ./frontend/vite.config.ts",
        "release-final": "bun ./extra/test-docker.ts && bun extra/update-version.ts && bun run build:frontend && bun run build:docker",
        "release-beta": "bun ./extra/test-docker.ts && bun extra/update-version.ts && bun run build:frontend && bun run build:docker-beta",
        "build:frontend": "vite build --config ./frontend/vite.config.ts",
        "build:docker-base": "docker buildx build --platform linux/amd64,linux/arm64,linux/arm/v7 -t ghcr.io/arbour-app/arbour:base -f ./docker/Base.Dockerfile . --push",
        "build:docker": "docker buildx build --platform linux/amd64,linux/arm64,linux/arm/v7 -t ghcr.io/arbour-app/arbour:latest -t ghcr.io/arbour-app/arbour:1 -t ghcr.io/arbour-app/arbour:$VERSION -t ghcr.io/arbour-app/arbour:beta -t ghcr.io/arbour-app/arbour:nightly --target release -f ./docker/Dockerfile . --push",
        "build:docker-beta": "docker buildx build --platform linux/amd64,linux/arm64,linux/arm/v7 -t ghcr.io/arbour-app/arbour:beta -t ghcr.io/arbour-app/arbour:$VERSION --target release -f ./docker/Dockerfile . --push",
        "build:docker-nightly": "bun run build:frontend && docker buildx build --platform linux/amd64,linux/arm64,linux/arm/v7 -t ghcr.io/arbour-app/arbour:nightly --target nightly -f ./docker/Dockerfile . --push",
        "build:healthcheck": "docker buildx build -f docker/BuildHealthCheck.Dockerfile --platform linux/amd64,linux/arm64,linux/arm/v7 -t ghcr.io/arbour-app/arbour:build-healthcheck . --push",
        "start-docker": "docker run --rm -p 5001:5001 --name arbour ghcr.io/arbour-app/arbour:latest",
        "mark-as-nightly": "bun ./extra/mark-as-nightly.ts",
        "reformat-changelog": "bun ./extra/reformat-changelog.ts",
        "reset-password": "bun ./extra/reset-password.ts"
    },
    "dependencies": {
        "@inventage/envsubst": "^0.16.0",
        "bcryptjs": "~2.4.3",
        "check-password-strength": "~2.0.10",
        "command-exists": "~1.2.9",
        "compare-versions": "~6.1.1",
        "composerize": "~1.7.1",
        "croner": "~8.1.2",
        "dayjs": "~1.11.13",
        "drizzle-orm": "^0.45.2",
        "express": "~4.21.2",
        "express-static-gzip": "~2.1.8",
        "http-graceful-shutdown": "~3.1.14",
        "jsonwebtoken": "~9.0.2",
        "jwt-decode": "~3.1.2",
        "limiter-es6-compat": "~2.1.2",
        "node-pty": "^1.1.0",
        "promisify-child-process": "~4.1.2",
        "semver": "^7.7.1",
        "socket.io": "~4.8.1",
        "socket.io-client": "~4.8.1",
        "timezones-list": "~3.0.3",
        "ts-command-line-args": "~2.5.1",
        "type-fest": "~4.3.3",
        "yaml": "~2.3.4"
    },
    "devDependencies": {
        "@actions/github": "^6.0.0",
        "@fontsource/jetbrains-mono": "^5.2.5",
        "@fortawesome/fontawesome-svg-core": "6.4.2",
        "@fortawesome/free-regular-svg-icons": "6.4.2",
        "@fortawesome/free-solid-svg-icons": "6.4.2",
        "@fortawesome/vue-fontawesome": "3.0.3",
        "@types/bcryptjs": "^2.4.6",
        "@types/bootstrap": "~5.2.10",
        "@types/command-exists": "~1.2.3",
        "@types/express": "~4.17.21",
        "@types/jsonwebtoken": "~9.0.9",
        "@types/semver": "^7.7.0",
        "@typescript-eslint/eslint-plugin": "~6.8.0",
        "@typescript-eslint/parser": "~6.8.0",
        "@vitejs/plugin-vue": "~5.2.3",
        "@xterm/addon-fit": "beta",
        "@xterm/xterm": "beta",
        "bootstrap": "5.3.8",
        "bootstrap-vue-next": "~0.40.5",
        "drizzle-kit": "^0.31.10",
        "eslint": "~8.50.0",
        "eslint-plugin-jsdoc": "~46.8.2",
        "eslint-plugin-vue": "~9.32.0",
        "prismjs": "~1.30.0",
        "sass": "~1.68.0",
        "typescript": "~5.2.2",
        "unplugin-vue-components": "~0.25.2",
        "vite": "~5.4.15",
        "vite-plugin-compression": "~0.5.1",
        "vue": "~3.5.13",
        "vue-eslint-parser": "~9.3.2",
        "vue-i18n": "~10.0.6",
        "vue-prism-editor": "2.0.0-alpha.2",
        "vue-qrcode": "~2.2.2",
        "vue-router": "~4.5.0",
        "vue-toastification": "2.0.0-rc.5",
        "xterm-addon-web-links": "~0.9.0"
    }
}
