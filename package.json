{
    "name": "arbour",
    "version": "0.3.2",
    "type": "module",
    "engines": {
        "bun": ">= 1.3.0"
    },
    "scripts": {
        "fmt": "eslint \"**/*.{ts,vue}\" --fix",
        "lint": "eslint \"**/*.{ts,vue}\"",
        "typecheck": "vue-tsc -b --pretty --noEmit",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "verify": "bun run fmt && bun run typecheck && bun run test",
        "start": "bun ./backend/index.ts",
        "dev": "bun ./extra/dev.ts",
        "dev:backend": "NODE_ENV=development bun --watch ./backend/index.ts",
        "dev:frontend": "NODE_ENV=development vite --host --strictPort --config ./frontend/vite.config.ts",
        "build:frontend": "vite build --config ./frontend/vite.config.ts",
        "build:docker-local": "docker build --target release -f ./docker/Dockerfile -t arbour:local .",
        "start-docker": "docker run --rm -p 5001:5001 --name arbour arbour:local",
        "reset-password": "bun ./extra/reset-password.ts",
        "hard-reset": "rm -rf ./data ./stacks"
    },
    "dependencies": {
        "@inventage/envsubst": "^0.17.0",
        "bcryptjs": "^3.0.3",
        "bun-pty": "^0.4.8",
        "check-password-strength": "^3.0.0",
        "command-exists": "~1.2.9",
        "composerize": "~1.7.5",
        "croner": "^10.0.1",
        "dayjs": "^1.11.20",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "express-static-gzip": "^3.0.0",
        "http-graceful-shutdown": "~3.1.16",
        "jsonwebtoken": "~9.0.3",
        "jwt-decode": "^4.0.0",
        "limiter-es6-compat": "~2.1.2",
        "semver": "^7.7.4",
        "socket.io": "~4.8.3",
        "socket.io-client": "~4.8.3",
        "timezones-list": "^3.1.0",
        "ts-command-line-args": "~2.5.1",
        "type-fest": "^5.6.0",
        "vue-tsc": "^3.2.7",
        "yaml": "^2.8.3"
    },
    "devDependencies": {
        "@actions/github": "^9.1.1",
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-yaml": "^6.1.3",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@eslint/js": "^10.0.1",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-regular-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.2.0",
        "@types/bcryptjs": "^3.0.0",
        "@types/bootstrap": "~5.2.10",
        "@types/bun": "^1.3.13",
        "@types/command-exists": "~1.2.3",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "~9.0.10",
        "@types/semver": "^7.7.1",
        "@vitejs/plugin-vue": "^6.0.6",
        "@xterm/addon-fit": "beta",
        "@xterm/xterm": "beta",
        "bootstrap": "^5.3.8",
        "bootstrap-vue-next": "^0.44.7",
        "codemirror": "^6.0.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.2.1",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-vue": "^10.9.0",
        "globals": "^17.5.0",
        "sass": "^1.99.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.0",
        "unplugin-vue-components": "^32.0.0",
        "vite": "^8.0.10",
        "vite-plugin-compression": "^0.5.1",
        "vue": "^3.5.33",
        "vue-codemirror": "^6.1.1",
        "vue-i18n": "^11.4.0",
        "vue-qrcode": "~2.2.2",
        "vue-router": "^5.0.6",
        "vue-toastification": "2.0.0-rc.5"
    }
}
