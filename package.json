{
    "name": "arbour",
    "version": "0.4.7",
    "type": "module",
    "engines": {
        "bun": ">= 1.3.14"
    },
    "scripts": {
        "fmt": "eslint \"**/*.{ts,svelte}\" --fix",
        "lint": "eslint \"**/*.{ts,svelte}\"",
        "typecheck": "svelte-kit sync && svelte-check --tsconfig ./frontend/tsconfig.json",
        "test": "ARBOUR_HIDE_LOG=error_console,error_autoupdate bun test",
        "test:watch": "ARBOUR_HIDE_LOG=error_console,error_autoupdate bun test --watch",
        "verify": "bun ./extra/verify.ts",
        "start": "bun ./backend/index.ts",
        "dev": "bun ./extra/dev.ts",
        "dev:backend": "NODE_ENV=development bun --watch ./backend/index.ts",
        "dev:frontend": "NODE_ENV=development vite dev --host --strictPort --config ./frontend/vite.config.ts",
        "build:frontend": "vite build --config ./frontend/vite.config.ts",
        "build:docker-local": "bun run build:frontend && docker build --target release -f ./docker/Dockerfile -t arbour:local .",
        "start-docker": "docker run --rm -p 5001:5001 --name arbour arbour:local",
        "reset-password": "bun ./extra/reset-password.ts",
        "hard-reset": "rm -rf ./data ./stacks",
        "release:patch": "npm version patch -m 'chore: release v%s' && git push --follow-tags",
        "release:minor": "npm version minor -m 'chore: release v%s' && git push --follow-tags",
        "release:major": "npm version major -m 'chore: release v%s' && git push --follow-tags"
    },
    "dependencies": {
        "@inventage/envsubst": "^0.17.0",
        "bcryptjs": "^3.0.3",
        "bun-pty": "^0.4.9",
        "check-password-strength": "^3.0.0",
        "command-exists": "~1.2.9",
        "composerize": "~1.7.6",
        "croner": "^10.0.1",
        "dayjs": "^1.11.21",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "express-static-gzip": "^3.0.1",
        "http-graceful-shutdown": "~3.1.16",
        "jsonwebtoken": "~9.0.3",
        "jwt-decode": "^4.0.0",
        "limiter-es6-compat": "~2.1.2",
        "semver": "^7.8.4",
        "socket.io": "~4.8.3",
        "socket.io-client": "~4.8.3",
        "timezones-list": "^3.1.0",
        "ts-command-line-args": "~2.5.1",
        "type-fest": "^5.7.0",
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@codemirror/lang-json": "^6.0.2",
        "@codemirror/lang-yaml": "^6.1.3",
        "@eslint/js": "^10.0.1",
        "@fontsource/jetbrains-mono": "^5.2.8",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@sveltejs/adapter-static": "^3.0.10",
        "@sveltejs/kit": "^2.65.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@types/bcryptjs": "^3.0.0",
        "@types/bun": "^1.3.14",
        "@types/command-exists": "~1.2.3",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "~9.0.10",
        "@types/qrcode": "^1.5.6",
        "@types/semver": "^7.7.1",
        "@xterm/addon-fit": "0.12.0-beta.216",
        "@xterm/xterm": "6.1.0-beta.216",
        "codemirror": "^6.0.2",
        "eslint": "^10.4.1",
        "eslint-plugin-svelte": "^3.19.0",
        "globals": "^17.6.0",
        "qrcode": "^1.5.4",
        "sass": "^1.101.0",
        "svelte": "^5.56.3",
        "svelte-check": "^4.6.0",
        "svelte-i18n": "^4.0.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16",
        "vite-plugin-compression": "^0.5.1"
    }
}
